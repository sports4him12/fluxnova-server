<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://fluxnova.com/bpmn">

  <process id="trip-planning-process"
           name="Trip Planning Process"
           isExecutable="true"
           camunda:historyTimeToLive="P90D">

    <!-- ── 1. Start ─────────────────────────────────────────────────────── -->
    <startEvent id="start" name="Trip Planning&#10;Started">
      <outgoing>flow-start-to-gather</outgoing>
    </startEvent>

    <!-- ── 2. AI Chat: gather trip details ──────────────────────────────── -->
    <userTask id="gather-trip-details"
              name="Gather Trip Details&#10;via AI Chat"
              camunda:formKey="gather-trip-details">
      <documentation>
        The traveller uses the AI Chat Agent to describe their ideal trip:
        destination preferences, travel window, budget, group size, and any
        special requirements. The agent stores the collected details as
        process variables (destination, season, budget, groupSize, notes).
      </documentation>
      <incoming>flow-start-to-gather</incoming>
      <incoming>flow-needs-changes</incoming>
      <outgoing>flow-gather-to-review</outgoing>
    </userTask>

    <!-- ── 3. Human approval: review and confirm ────────────────────────── -->
    <userTask id="review-and-confirm"
              name="Review &amp; Confirm&#10;Trip Details"
              camunda:formKey="review-and-confirm">
      <documentation>
        The traveller reviews a summary of the details gathered by the AI
        agent and either confirms them (confirmed=true) or requests changes
        (confirmed=false), which loops back to this step.
      </documentation>
      <incoming>flow-gather-to-review</incoming>
      <outgoing>flow-review-to-gateway</outgoing>
    </userTask>

    <!-- ── 4. Gateway: confirmed? ────────────────────────────────────────── -->
    <exclusiveGateway id="confirmed-gateway" name="Details&#10;Confirmed?">
      <incoming>flow-review-to-gateway</incoming>
      <outgoing>flow-approved</outgoing>
      <outgoing>flow-needs-changes</outgoing>
    </exclusiveGateway>

    <!-- ── 5. Generate Trip PDF ──────────────────────────────────────────── -->
    <userTask id="generate-trip-pdf"
              name="Generate Trip PDF"
              camunda:formKey="generate-trip-pdf">
      <documentation>
        The traveller clicks "Download Trip PDF" to generate and download a PDF
        summary of all confirmed trip details, then completes this task to finish
        the workflow.
      </documentation>
      <incoming>flow-approved</incoming>
      <outgoing>flow-pdf-to-end</outgoing>
    </userTask>

    <!-- ── 6. End ─────────────────────────────────────────────────────────── -->
    <endEvent id="end" name="Trip PDF Ready">
      <incoming>flow-pdf-to-end</incoming>
    </endEvent>

    <!-- ── Sequence Flows ─────────────────────────────────────────────────── -->
    <sequenceFlow id="flow-start-to-gather"   sourceRef="start"               targetRef="gather-trip-details"/>
    <sequenceFlow id="flow-gather-to-review"  sourceRef="gather-trip-details"  targetRef="review-and-confirm"/>
    <sequenceFlow id="flow-review-to-gateway" sourceRef="review-and-confirm"   targetRef="confirmed-gateway"/>

    <sequenceFlow id="flow-approved" name="Yes" sourceRef="confirmed-gateway" targetRef="generate-trip-pdf">
      <conditionExpression xsi:type="tFormalExpression">${confirmed == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow-needs-changes" name="No — Request Changes" sourceRef="confirmed-gateway" targetRef="gather-trip-details">
      <conditionExpression xsi:type="tFormalExpression">${confirmed != true}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow-pdf-to-end" sourceRef="generate-trip-pdf" targetRef="end"/>

  </process>

  <!-- ── Diagram Interchange (required for Cockpit rendering) ─────────────── -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_trip-planning">
    <bpmndi:BPMNPlane id="BPMNPlane_trip-planning" bpmnElement="trip-planning-process">

      <!-- Start -->
      <bpmndi:BPMNShape id="shape-start" bpmnElement="start">
        <dc:Bounds x="152" y="202" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="130" y="245" width="80" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Gather Trip Details -->
      <bpmndi:BPMNShape id="shape-gather" bpmnElement="gather-trip-details">
        <dc:Bounds x="240" y="180" width="130" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- Review & Confirm -->
      <bpmndi:BPMNShape id="shape-review" bpmnElement="review-and-confirm">
        <dc:Bounds x="430" y="180" width="130" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- Confirmed? Gateway -->
      <bpmndi:BPMNShape id="shape-gateway" bpmnElement="confirmed-gateway" isMarkerVisible="true">
        <dc:Bounds x="625" y="195" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="608" y="252" width="84" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Generate Trip PDF -->
      <bpmndi:BPMNShape id="shape-pdf" bpmnElement="generate-trip-pdf">
        <dc:Bounds x="740" y="180" width="130" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- End -->
      <bpmndi:BPMNShape id="shape-end" bpmnElement="end">
        <dc:Bounds x="942" y="202" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="920" y="245" width="80" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- flow-start-to-gather -->
      <bpmndi:BPMNEdge id="edge-start-gather" bpmnElement="flow-start-to-gather">
        <di:waypoint x="188" y="220"/>
        <di:waypoint x="240" y="220"/>
      </bpmndi:BPMNEdge>

      <!-- flow-gather-to-review -->
      <bpmndi:BPMNEdge id="edge-gather-review" bpmnElement="flow-gather-to-review">
        <di:waypoint x="370" y="220"/>
        <di:waypoint x="430" y="220"/>
      </bpmndi:BPMNEdge>

      <!-- flow-review-to-gateway -->
      <bpmndi:BPMNEdge id="edge-review-gateway" bpmnElement="flow-review-to-gateway">
        <di:waypoint x="560" y="220"/>
        <di:waypoint x="625" y="220"/>
      </bpmndi:BPMNEdge>

      <!-- flow-approved (Yes) -->
      <bpmndi:BPMNEdge id="edge-approved" bpmnElement="flow-approved">
        <di:waypoint x="675" y="220"/>
        <di:waypoint x="740" y="220"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="693" y="202" width="18" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- flow-needs-changes (No — loops back to gather-trip-details) -->
      <bpmndi:BPMNEdge id="edge-needs-changes" bpmnElement="flow-needs-changes">
        <di:waypoint x="650" y="245"/>
        <di:waypoint x="650" y="340"/>
        <di:waypoint x="305" y="340"/>
        <di:waypoint x="305" y="260"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="440" y="322" width="90" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- flow-pdf-to-end -->
      <bpmndi:BPMNEdge id="edge-pdf-end" bpmnElement="flow-pdf-to-end">
        <di:waypoint x="870" y="220"/>
        <di:waypoint x="942" y="220"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
